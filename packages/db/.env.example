# Supabase Cloud dev project (dashboard → Settings → API).
# Service role seeds data (bypasses RLS); anon key drives the RLS integration test.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>
# Password set on the seeded dev users (owner/manager/staff @mrocha.test).
SEED_PASSWORD=hub-dev-2026!
