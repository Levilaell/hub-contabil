{
  "name": "@hub/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:push": "supabase db push",
    "db:new": "supabase migration new",
    "db:types": "supabase gen types typescript --linked --schema public > src/database.types.ts",
    "seed": "node --env-file=.env --import tsx src/seed.ts",
    "seed:demo": "node --env-file=.env --import tsx src/seed-demo.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hub/config": "workspace:*",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@hub/core": "workspace:*",
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
