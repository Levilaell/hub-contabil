# Supabase Cloud dev project (dashboard → Settings → API / Database)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Session pooler (port 5432); URL-encode special characters in the password
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:5432/postgres

# Base URL used to build the public request link (/s/{token}) in reminder e-mails.
APP_BASE_URL=http://localhost:3000

# Resend e-mail (T17). Leave unset to keep the no-op adapter (logs, no send).
# RESEND_FROM must be a verified sender, e.g. "Demo <no-reply@yourdomain.com>".
RESEND_API_KEY=
RESEND_FROM=

# AI triage + atendimento. Leave unset to keep the heuristic no-op (everything →
# exception queue; the support assistant escalates everything to a human).
ANTHROPIC_API_KEY=

# WhatsApp Cloud API (entrada via WhatsApp + atendimento). Leave unset to keep the
# no-op adapter (inbound parsing still works for tests; no send/download). All three
# of token/phone/secret are required to enable the real adapter.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# IMAP inbox monitoring (entrada por e-mail). Leave host/user/password unset to keep
# the no-op (the inbound-imap poll cron is not scheduled). Port defaults to 993,
# secure to true.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_SECURE=true
