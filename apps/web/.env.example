# Supabase Cloud dev project (dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only. Used ONLY by the public request page (/s/[token]) server actions to
# mint signed Storage upload/download URLs — the visitor has no firm session.
# NEVER prefix with NEXT_PUBLIC_ and never import into a client component.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Resend e-mail (T17). Leave unset to keep the no-op adapter (logs, no send).
# RESEND_FROM must be a verified sender, e.g. "Demo <no-reply@yourdomain.com>".
RESEND_API_KEY=
RESEND_FROM=

# WhatsApp Cloud API webhook (/api/webhooks/whatsapp). The app secret verifies the
# X-Hub-Signature-256 of inbound posts; the verify token answers Meta's GET probe.
# Set the same four values as the worker so the webhook can validate signatures.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Single-tenant firm id the webhook stamps inbound on. Optional — falls back to the
# single firms row when unset.
FIRM_ID=
